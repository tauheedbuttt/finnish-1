{
  "topic": "localcases",
  "title": "Paikallissijat - Local Cases",
  "description": "Practice Finnish local cases - Missä (where), Mistä (from where), Mihin (to where)",
  "instructions": "Add the correct ending based on the location type and direction",
  "subtopics": [
    { "id": "all", "name": "All Cases", "icon": "📚" },
    { "id": "s-case", "name": "Missä: -ssa/-ssä", "icon": "🏠" },
    { "id": "l-case", "name": "Missä: -lla/-llä", "icon": "🌳" },
    { "id": "mista-s", "name": "Mistä: -sta/-stä", "icon": "⬅️" },
    { "id": "mista-l", "name": "Mistä: -lta/-ltä", "icon": "↩️" },
    { "id": "mihin-s", "name": "Mihin: -Vn/-seen/-hVn", "icon": "➡️" },
    { "id": "mihin-l", "name": "Mihin: -lle", "icon": "↪️" },
    { "id": "special", "name": "Special Words", "icon": "⭐" },
    { "id": "cities", "name": "Cities & Countries", "icon": "🌍" }
  ],
  "rules": {
    "overview": {
      "description": "Finnish local cases show location and direction",
      "cases": {
        "missä": "Where (static) - no movement",
        "mistä": "From where - movement away from",
        "mihin": "To where - movement towards"
      },
      "types": {
        "internal": "S-cases: -ssa/-stä/-Vn (inside places)",
        "external": "L-cases: -lla/-lta/-lle (outside/surface places)"
      },
      "note": "Internal cases (S) use strong grade KPT, external cases (L) use weak grade KPT"
    },
    "missä": {
      "description": "Missä = Where (in/at/on) - used with STATIC verbs",
      "static_verbs": [
        "olla",
        "asua",
        "istua",
        "seistä",
        "maata",
        "nukkua",
        "työskennellä"
      ],
      "note": "No movement - staying in one place"
    },
    "mistä": {
      "description": "Mistä = From where - used with verbs of LEAVING/COMING FROM",
      "verbs": ["tulla", "lähteä", "mennä pois", "ottaa"],
      "internal": {
        "ending": "-sta / -stä",
        "rule": "Attach to stem of word (coming from INSIDE)",
        "examples": ["talosta", "kaupasta", "Suomesta"]
      },
      "external": {
        "ending": "-lta / -ltä",
        "rule": "Attach to stem of word (coming from OUTSIDE/surface)",
        "examples": ["kadulta", "pöydältä", "rannalta"]
      },
      "vowel_harmony": {
        "a/o/u": "-sta / -lta",
        "ä/ö/y/e/i": "-stä / -ltä"
      }
    },
    "mihin": {
      "description": "Mihin = To where - used with verbs of GOING/MOVING TO",
      "verbs": ["mennä", "tulla", "lähteä", "matkustaa", "muuttaa"],
      "internal": {
        "type_1_Vn": {
          "rule": "Stem ends with 1 vowel → add 'n'",
          "examples": [
            { "word": "talo", "stem": "talo-", "mihin": "taloon" },
            { "word": "nainen", "stem": "naise-", "mihin": "naiseen" },
            { "word": "Suomi", "stem": "Suome-", "mihin": "Suomeen" }
          ],
          "special": "For si/ia/ea words, use long stem: uusi → uuteen, Italia → Italiaan"
        },
        "type_2_seen": {
          "rule": "Stem ends with 2 identical vowels → add 'seen'",
          "examples": [
            { "word": "huone", "stem": "huonee-", "mihin": "huoneeseen" },
            { "word": "Lontoo", "stem": "Lontoo-", "mihin": "Lontooseen" }
          ]
        },
        "type_3_hVn": {
          "rule": "Short words (1 syllable) ending in 2 vowels → add 'hVn' (V = last vowel)",
          "examples": [
            { "word": "maa", "mihin": "maahan" },
            { "word": "suu", "mihin": "suuhun" },
            { "word": "puu", "mihin": "puuhun" },
            { "word": "työ", "mihin": "työhön" }
          ],
          "weekdays": "Weekdays ending with 'tai' → add 'hin': maanantaihin, tiistaihin"
        }
      },
      "external": {
        "ending": "-lle",
        "rule": "Attach 'lle' to stem of word (going TO outside/surface)",
        "examples": ["kadulle", "pöydälle", "rannalle"]
      }
    },
    "s_case": {
      "ending": "-ssa / -ssä",
      "when_to_use": [
        {
          "rule": "Closed places",
          "examples": ["kaupassa", "talossa", "autossa"]
        },
        {
          "rule": "Inside something",
          "examples": ["laatikossa", "laukussa", "taskussa"]
        },
        {
          "rule": "Most city/country names",
          "examples": ["Helsingissä", "Suomessa", "Turussa"]
        },
        {
          "rule": "Areas/regions",
          "examples": ["Euroopassa", "Afrikassa", "keskustassa"]
        }
      ],
      "vowel_harmony": {
        "a/o/u": "-ssa",
        "ä/ö/y/e/i": "-ssä"
      }
    },
    "l_case": {
      "ending": "-lla / -llä",
      "when_to_use": [
        {
          "rule": "Outside/open places",
          "examples": ["kadulla", "torilla", "pihalla"]
        },
        {
          "rule": "On a surface",
          "examples": ["pöydällä", "lattialla", "seinällä"]
        },
        { "rule": "Near/at", "examples": ["ovella", "ikkunalla", "rannalla"] },
        {
          "rule": "Some activities",
          "examples": ["tunnilla", "luennolla", "töissä→töillä (spoken)"]
        }
      ],
      "vowel_harmony": {
        "a/o/u": "-lla",
        "ä/ö/y/e/i": "-llä"
      }
    },
    "special_words": {
      "description": "Some words have special forms",
      "words": [
        {
          "word": "koti",
          "missä": "kotona",
          "mistä": "kotoa",
          "mihin": "kotiin",
          "note": "at/from/to home"
        },
        {
          "word": "ulko",
          "missä": "ulkona",
          "mistä": "ulkoa",
          "mihin": "ulos",
          "note": "outside"
        },
        {
          "word": "sisä",
          "missä": "sisällä",
          "mistä": "sisältä",
          "mihin": "sisään",
          "note": "inside"
        }
      ]
    }
  },
